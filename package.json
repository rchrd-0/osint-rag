{
  "name": "osint-rag",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "ai": "^6.0.3",
      "next-themes": "^0.4.6",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "bun run --elide-lines=0 --filter '*' dev",
    "build": "bun run --filter '*' build",
    "check-types": "bun run --filter '*' check-types",
    "dev:web": "bun run --filter web dev",
    "dev:server": "bun run --filter server dev",
    "db:push": "bun run --filter @osint-rag/db db:push",
    "db:studio": "bun run --filter @osint-rag/db db:studio",
    "db:generate": "bun run --filter @osint-rag/db db:generate",
    "db:migrate": "bun run --filter @osint-rag/db db:migrate",
    "db:start": "bun run --filter @osint-rag/db db:start",
    "db:watch": "bun run --filter @osint-rag/db db:watch",
    "db:stop": "bun run --filter @osint-rag/db db:stop",
    "db:down": "bun run --filter @osint-rag/db db:down",
    "db:seed": "bun run --filter @osint-rag/db db:seed",
    "db:reset": "bun run --cwd packages/db db:reset",
    "docs:chunk": "bun run --elide-lines=0 --filter server docs:chunk",
    "ingest:guardian": "bun run --elide-lines=0 --filter server ingest:guardian",
    "check": "biome check  .",
    "check:fix": "biome check --write ."
  },
  "dependencies": {
    "@osint-rag/env": "workspace:*",
    "dotenv": "catalog:",
    "ai": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@osint-rag/config": "workspace:*",
    "@types/bun": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.9"
}
