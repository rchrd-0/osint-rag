{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs",
    "docs:chunk": "bun run src/scripts/chunk-documents.ts",
    "docs:embed": "bun run src/scripts/embed-chunk.ts",
    "ingest:guardian": "bun run src/scripts/guardian-ingest.ts"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@osint-rag/db": "workspace:*",
    "@osint-rag/env": "workspace:*",
    "@osint-rag/schemas": "workspace:*",
    "@osint-rag/types": "workspace:*",
    "ai": "catalog:",
    "dotenv": "catalog:",
    "hono": "^4.8.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@osint-rag/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.21.9",
    "typescript": "catalog:"
  }
}
